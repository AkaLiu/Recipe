---
const categories = [
  { name: '鲁', label: '鲁菜', path: '/Recipe/鲁' },
  { name: '川', label: '川菜', path: '/Recipe/川' },
  { name: '粤闽', label: '粤闽', path: '/Recipe/粤闽' },
  { name: '淮扬', label: '淮扬', path: '/Recipe/淮扬' },
  { name: '徽湘', label: '徽湘', path: '/Recipe/徽湘' },
  { name: '云贵', label: '云贵', path: '/Recipe/云贵' },
  { name: '意法', label: '意法', path: '/Recipe/意法' },
  { name: '南洋', label: '南洋', path: '/Recipe/南洋' },
  { name: 'Silk-Road', label: '丝路', path: '/Recipe/Silk-Road' },
  { name: 'Latin-America', label: '拉美', path: '/Recipe/Latin-America' },
  { name: 'Japan-Korea', label: '日韩', path: '/Recipe/Japan-Korea' },
  { name: 'Fast-Food', label: '快餐', path: '/Recipe/Fast-Food' },
  { name: 'Desserts', label: '甜点', path: '/Recipe/Desserts' },
  { name: 'Drinks', label: '饮品', path: '/Recipe/Drinks' },
];

const currentPath = Astro.url.pathname;
---

<header class="glass-nav sticky top-0 z-50 no-print shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="h-16 lg:h-[4.75rem] grid grid-cols-[1fr_auto_1fr] items-center gap-3">
      <div class="hidden lg:flex items-center gap-5 justify-start">
        <a href="/Recipe/book" class="nav-utility-link nav-utility-link-featured">
          Recipe Book
        </a>
        <a href="/Recipe#favorites" class="nav-utility-link">
          Favorites
        </a>
      </div>

      <div class="flex items-center justify-start lg:hidden">
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-none text-linen-100/80 hover:bg-white/10 hover:text-white transition-colors"
          aria-label="菜单"
          aria-expanded="false"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <div class="flex flex-col items-center justify-center">
        <a href="/Recipe" class="group text-center">
          <span class="block font-condensed text-[0.72rem] uppercase tracking-[0.28em] text-copper-300 mb-1">
            Home Recipe Archive
          </span>
          <span class="font-display text-[1.7rem] lg:text-[2.35rem] leading-none font-semibold text-linen-50 tracking-[0.03em] group-hover:text-white transition-colors">
            Piglet&apos;s Gourmet Odyssey
          </span>
        </a>
      </div>

      <div class="hidden lg:flex items-center justify-end">
        <a href="/Recipe#categories" class="nav-utility-link">
          Cuisines
        </a>
      </div>
    </div>

    <div class="hidden lg:flex justify-center pb-4">
      <div class="nav-category-strip">
        {categories.map((cat) => (
          <a
            href={cat.path}
            class:list={[
              'nav-category-link',
              currentPath === cat.path
                ? 'nav-category-link-active'
                : 'nav-category-link-idle'
            ]}
          >
            {cat.label}
            {currentPath === cat.path && (
              <span class="absolute left-1/2 top-full mt-1.5 -translate-x-1/2 h-px w-5 bg-copper-500" />
            )}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Mobile Overlay -->
  <div id="mobile-overlay" class="fixed inset-0 bg-brown-900/30 backdrop-blur-sm z-40 hidden lg:hidden opacity-0 transition-opacity duration-300"></div>

  <!-- Mobile Slide-out Menu -->
  <div id="mobile-menu" class="fixed top-0 right-0 h-full w-72 bg-[linear-gradient(180deg,rgba(44,32,28,0.99)_0%,rgba(34,26,23,0.99)_100%)] shadow-xl z-50 transform translate-x-full transition-transform duration-300 ease-out lg:hidden">
    <div class="p-6 pt-8">
      <div class="flex items-center justify-between mb-8">
        <span class="font-serif font-bold text-linen-50 text-lg">菜系分类</span>
        <button id="mobile-close-btn" class="p-2 rounded-none hover:bg-white/10 text-linen-100/70">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="flex flex-col gap-1">
        <a href="/Recipe#favorites" class="px-4 py-2.5 rounded-none text-sm font-medium text-linen-50 bg-white/10 mb-2">
          我的收藏
        </a>
        {categories.map((cat) => (
          <a
            href={cat.path}
            class:list={[
              'px-4 py-2.5 rounded-none text-sm font-medium transition-all duration-200',
              currentPath === cat.path
                ? 'bg-white/10 text-copper-300 border-l-2 border-copper-500'
                : 'text-linen-100/75 hover:bg-white/8 hover:text-white'
            ]}
          >
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-overlay');

  function openMenu() {
    menu?.classList.remove('translate-x-full');
    overlay?.classList.remove('hidden');
    requestAnimationFrame(() => overlay?.classList.remove('opacity-0'));
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('translate-x-full');
    overlay?.classList.add('opacity-0');
    setTimeout(() => overlay?.classList.add('hidden'), 300);
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);
</script>
