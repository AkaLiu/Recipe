---
import { getCollection } from 'astro:content';
import RecipeLayout from '../../layouts/RecipeLayout.astro';
import { getRecipeImageSrc } from '../../utils/imageAssets';

export async function getStaticPaths() {
  const categories = ['鲁', '川', '粤闽', '淮扬', '徽湘', '云贵', '意法', '南洋', 'Silk-Road', 'Latin-America', 'Japan-Korea', 'Fast-Food', 'Desserts', 'Drinks'];
  return categories.map((category) => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props;
const allRecipes = await getCollection('recipes');
const categoryRecipes = allRecipes.filter((r) => r.data.category === category);

const categoryLabels: Record<string, string> = {
  '鲁': '鲁菜',
  '川': '川菜',
  '粤闽': '粤闽',
  '淮扬': '淮扬',
  '徽湘': '徽湘',
  '云贵': '云贵',
  '意法': '意法',
  '南洋': '南洋',
  'Silk-Road': '丝路风味',
  'Latin-America': '拉美',
  'Japan-Korea': '日韩',
  'Fast-Food': '快餐',
  'Desserts': '甜点',
  'Drinks': '饮品',
};

const categoryDescriptions: Record<string, string> = {
  '鲁': 'The refined cuisine of Shandong, master of seafood and clear broths',
  '川': 'Bold Sichuan flavors, the art of mala and complex spice',
  '粤闽': 'Cantonese and Fujian traditions of freshness and subtlety',
  '淮扬': 'Huaiyang elegance, precise knife skills and delicate tastes',
  '徽湘': 'Anhui and Hunan home cooking, earthy and fragrant',
  '云贵': 'Yunnan and Guizhou, sour-spicy mountain flavors',
  '意法': 'Italian and French classics, Mediterranean warmth',
  '南洋': 'Southeast Asian vibrancy, tropical aromatics',
  'Silk-Road': 'Silk Road inspirations, where East meets West',
  'Latin-America': 'Latin American flavors, bright acids and fire-charred depth',
  'Japan-Korea': 'Japanese and Korean staples, clean structure and savory focus',
  'Fast-Food': 'Comforting quick bites and casual classics',
  'Desserts': 'Sweet endings and pastry creations',
  'Drinks': 'Beverages and refreshments',
};

function getRecipeSlug(id: string) {
  return id.replace(/\.mdx?$/, '').split('/').pop() || '';
}

function getRecipeSummary(body: string) {
  const lines = body
    .replace(/^---[\s\S]*?---\s*/, '')
    .split('\n')
    .map((line) => line.trim())
    .filter(Boolean)
    .filter((line) => !line.startsWith('##'))
    .filter((line) => !line.startsWith('|'))
    .filter((line) => !line.startsWith('-'))
    .filter((line) => !/^\d+\./.test(line));

  return lines[0] || 'A structured recipe from this chapter, styled as a cleaner editorial card instead of a basic markdown list.';
}
---

<RecipeLayout title={`${categoryLabels[category]} | 菜谱`}>
  <section class="bg-gradient-to-b from-linen-100 to-linen-50 py-16 md:py-24 border-b border-linen-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-warm-gray-400 mb-8">
        <a href="/Recipe" class="hover:text-wine-700 transition-colors">首页</a>
        <span>/</span>
        <span class="text-brown-800 font-medium">{categoryLabels[category]}</span>
      </nav>

      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_15rem] lg:items-end">
        <div>
          <p class="eyebrow mb-4">Recipe Chapter</p>
          <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold text-brown-800 tracking-tight mb-4">
            {categoryLabels[category]}
          </h1>
          <p class="text-warm-gray-500 max-w-2xl italic font-serif text-lg leading-8">
            {categoryDescriptions[category]}
          </p>
        </div>
        <div class="rounded-[1.5rem] border border-linen-200 bg-white/80 p-5 shadow-[0_12px_28px_rgba(93,67,42,0.05)]">
          <p class="font-condensed text-[0.72rem] uppercase tracking-[0.18em] text-copper-700 mb-2">In This Chapter</p>
          <p class="font-serif text-3xl font-semibold text-brown-800">{categoryRecipes.length}</p>
          <p class="text-sm text-warm-gray-500 mt-2">recipes presented in a cleaner editorial layout.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {categoryRecipes.length > 0 ? (
        <div class="space-y-8">
          {categoryRecipes.map((recipe, index) => (
            <a
              href={`/Recipe/${recipe.data.category}/${getRecipeSlug(recipe.id)}`}
              class="chapter-recipe-card animate-on-scroll group"
            >
              <div class="chapter-recipe-media">
                <img
                  src={getRecipeImageSrc(recipe.data.coverImage)}
                  alt={recipe.data.title}
                  class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                  loading="lazy"
                />
              </div>
              <div class="chapter-recipe-copy">
                <div class="flex flex-wrap items-center gap-3 text-[0.72rem] font-condensed uppercase tracking-[0.16em] text-copper-700">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <span>{categoryLabels[category]}</span>
                  {recipe.data.prepTime && <span>Prep {recipe.data.prepTime}</span>}
                  {recipe.data.cookTime && <span>Cook {recipe.data.cookTime}</span>}
                </div>
                <h2 class="mt-4 font-serif text-3xl md:text-4xl font-semibold text-brown-800 leading-tight group-hover:text-wine-700 transition-colors">
                  {recipe.data.title}
                </h2>
                {recipe.data.titleEn && (
                  <p class="mt-2 text-lg text-warm-gray-500 italic">{recipe.data.titleEn}</p>
                )}
                <div class="w-12 h-px bg-copper-500 mt-5 mb-5 group-hover:w-20 transition-all duration-500"></div>
                <p class="text-base leading-8 text-brown-700 max-w-2xl">
                  {getRecipeSummary(recipe.body)}
                </p>
                <div class="mt-6 flex flex-wrap gap-3 text-sm text-warm-gray-500">
                  {recipe.data.servings && <span>Serves {recipe.data.servings}</span>}
                  {recipe.data.bakeTime && <span>{recipe.data.bakeTime}</span>}
                  {recipe.data.robot && <span>{recipe.data.robot}</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 max-w-md mx-auto">
          <div class="w-16 h-16 rounded-full bg-linen-200 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-warm-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-brown-800 mb-2">暂无菜谱</h3>
          <p class="text-warm-gray-500 text-sm mb-8 leading-relaxed">
            This collection is still growing. Check back soon for new recipes.
          </p>
          <a href="/Recipe" class="btn-primary">
            返回首页
          </a>
        </div>
      )}
    </div>
  </section>
</RecipeLayout>
