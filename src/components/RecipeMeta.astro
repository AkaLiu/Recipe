---
interface Props {
  prepTime?: string;
  cookTime?: string;
  bakeTime?: string;
  coolTime?: string;
  difficulty?: 'easy' | 'medium' | 'hard';
  robot?: string;
}

const { prepTime, cookTime, bakeTime, coolTime, difficulty, robot } = Astro.props;

const starCount = difficulty === 'easy' ? 1 : difficulty === 'medium' ? 2 : 3;
---

<div class="recipe-meta-grid">
  {prepTime && (
    <div class="recipe-meta-chip">
      <span class="recipe-meta-icon">
        <svg class="w-4 h-4 text-copper-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </span>
      <span class="recipe-meta-label">准备时间</span>
      <strong class="recipe-meta-value">{prepTime}</strong>
    </div>
  )}

  {cookTime && (
    <div class="recipe-meta-chip">
      <span class="recipe-meta-icon">
        <svg class="w-4 h-4 text-copper-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
        </svg>
      </span>
      <span class="recipe-meta-label">烹饪时间</span>
      <strong class="recipe-meta-value">{cookTime}</strong>
    </div>
  )}

  {bakeTime && (
    <div class="recipe-meta-chip">
      <span class="recipe-meta-icon">
        <svg class="w-4 h-4 text-copper-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
        </svg>
      </span>
      <span class="recipe-meta-label">烘烤温度</span>
      <strong class="recipe-meta-value">{bakeTime}</strong>
    </div>
  )}

  {coolTime && (
    <div class="recipe-meta-chip">
      <span class="recipe-meta-icon">
        <svg class="w-4 h-4 text-copper-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </span>
      <span class="recipe-meta-label">静置冷却</span>
      <strong class="recipe-meta-value">{coolTime}</strong>
    </div>
  )}

  {difficulty && (
    <div class="recipe-meta-chip recipe-meta-chip-accent">
      <span class="recipe-meta-icon">
        <svg class="w-4 h-4 text-wine-600" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
      </span>
      <span class="recipe-meta-label">上手难度</span>
      <strong class="recipe-meta-value text-wine-700">{'★'.repeat(starCount)}{'☆'.repeat(3 - starCount)}</strong>
    </div>
  )}

  {robot && (
    <div class="recipe-meta-chip">
      <span class="recipe-meta-icon">🤖</span>
      <span class="recipe-meta-label">器械辅助</span>
      <strong class="recipe-meta-value">{robot}</strong>
    </div>
  )}
</div>
