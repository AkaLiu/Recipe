---
const categories = [
  { name: '鲁', label: '鲁菜', path: '/Recipe/鲁' },
  { name: '川', label: '川菜', path: '/Recipe/川' },
  { name: '粤闽', label: '粤闽', path: '/Recipe/粤闽' },
  { name: '淮扬', label: '淮扬', path: '/Recipe/淮扬' },
  { name: '徽湘', label: '徽湘', path: '/Recipe/徽湘' },
  { name: '云贵', label: '云贵', path: '/Recipe/云贵' },
  { name: '意法', label: '意法', path: '/Recipe/意法' },
  { name: '南洋', label: '南洋', path: '/Recipe/南洋' },
  { name: 'Silk-Road', label: '丝路', path: '/Recipe/Silk-Road' },
  { name: 'Desserts', label: '甜点', path: '/Recipe/Desserts' },
  { name: 'Drinks', label: '饮品', path: '/Recipe/Drinks' },
];

const currentPath = Astro.url.pathname;
---

<header class="glass-nav sticky top-0 z-50 no-print shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-14">
      <a href="/Recipe" class="flex items-center gap-2.5 group">
        <span class="text-xl">🍳</span>
        <span class="font-display text-lg font-bold text-wine-800 tracking-tight group-hover:text-wine-600 transition-colors">
          菜谱收藏
        </span>
      </a>

      <!-- Desktop Menu -->
      <div class="hidden lg:flex items-center gap-0.5">
        {categories.map((cat) => (
          <a
            href={cat.path}
            class:list={[
              'relative px-3 py-1.5 text-sm font-medium transition-colors duration-200 rounded-md',
              currentPath === cat.path
                ? 'text-wine-700 bg-wine-50'
                : 'text-warm-gray-600 hover:text-wine-700 hover:bg-wine-50/50'
            ]}
          >
            {cat.label}
            {currentPath === cat.path && (
              <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-0.5 bg-copper-500 rounded-full" />
            )}
          </a>
        ))}
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-warm-gray-600 hover:bg-linen-100 hover:text-wine-700 transition-colors"
        aria-label="菜单"
        aria-expanded="false"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Overlay -->
  <div id="mobile-overlay" class="fixed inset-0 bg-brown-900/30 backdrop-blur-sm z-40 hidden lg:hidden opacity-0 transition-opacity duration-300"></div>

  <!-- Mobile Slide-out Menu -->
  <div id="mobile-menu" class="fixed top-0 right-0 h-full w-72 bg-white shadow-xl z-50 transform translate-x-full transition-transform duration-300 ease-out lg:hidden">
    <div class="p-6 pt-8">
      <div class="flex items-center justify-between mb-8">
        <span class="font-serif font-bold text-wine-800 text-lg">菜系分类</span>
        <button id="mobile-close-btn" class="p-2 rounded-lg hover:bg-linen-100 text-warm-gray-500">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="flex flex-col gap-1">
        {categories.map((cat) => (
          <a
            href={cat.path}
            class:list={[
              'px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200',
              currentPath === cat.path
                ? 'bg-wine-50 text-wine-700 border-l-2 border-copper-500'
                : 'text-warm-gray-600 hover:bg-linen-100 hover:text-wine-700'
            ]}
          >
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-overlay');

  function openMenu() {
    menu?.classList.remove('translate-x-full');
    overlay?.classList.remove('hidden');
    requestAnimationFrame(() => overlay?.classList.remove('opacity-0'));
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('translate-x-full');
    overlay?.classList.add('opacity-0');
    setTimeout(() => overlay?.classList.add('hidden'), 300);
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);
</script>
