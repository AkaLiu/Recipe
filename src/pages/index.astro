---
import { getCollection } from 'astro:content';
import RecipeLayout from '../layouts/RecipeLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import { getRecipeImageSrc } from '../utils/imageAssets';

const allRecipes = await getCollection('recipes');

// Group recipes by category
const recipesByCategory = allRecipes.reduce((acc, recipe) => {
  const category = recipe.data.category;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push({
    ...recipe.data,
    slug: recipe.slug,
  });
  return acc;
}, {} as Record<string, typeof allRecipes[0]['data'][]>);

const categories = [
  { name: '川', label: '川菜', labelEn: 'Sichuan', href: '/Recipe/川' },
  { name: '粤闽', label: '粤闽', labelEn: 'Canton & Fujian', href: '/Recipe/粤闽' },
  { name: '淮扬', label: '淮扬', labelEn: 'Huaiyang', href: '/Recipe/淮扬' },
  { name: '云贵', label: '云贵', labelEn: 'Yunnan & Guizhou', href: '/Recipe/云贵' },
  { name: '意法', label: '意法', labelEn: 'Italian & French', href: '/Recipe/意法' },
  { name: '南洋', label: '南洋', labelEn: 'Nanyang', href: '/Recipe/南洋' },
  { name: '鲁', label: '鲁菜', labelEn: 'Shandong', href: '/Recipe/鲁' },
  { name: '徽湘', label: '徽湘', labelEn: 'Anhui & Hunan', href: '/Recipe/徽湘' },
  { name: 'Silk-Road', label: '丝路', labelEn: 'Silk Road', href: '/Recipe/Silk-Road' },
  { name: 'Latin-America', label: '拉美', labelEn: 'Latin America', href: '/Recipe/Latin-America' },
  { name: 'Japan-Korea', label: '日韩', labelEn: 'Japan & Korea', href: '/Recipe/Japan-Korea' },
  { name: 'Fast-Food', label: '快餐', labelEn: 'Fast Food', href: '/Recipe/Fast-Food' },
  { name: 'Desserts', label: '甜点', labelEn: 'Desserts', href: '/Recipe/Desserts' },
  { name: 'Drinks', label: '饮品', labelEn: 'Drinks', href: '/Recipe/Drinks' },
];

const totalRecipes = allRecipes.length;
const spotlightRecipe = allRecipes[0];
const spotlightImage = spotlightRecipe ? getRecipeImageSrc(spotlightRecipe.data.coverImage) : '';
---

<RecipeLayout title="Piglet’s Gourmet Odyssey">
  <section class="relative min-h-[72vh] overflow-hidden border-b border-linen-200">
    {spotlightRecipe && (
      <>
        <img
          src={spotlightImage}
          alt={spotlightRecipe.data.title}
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(64,39,29,0.50)_0%,rgba(64,39,29,0.26)_34%,rgba(64,39,29,0.12)_58%,rgba(64,39,29,0.28)_100%)]"></div>
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(250,247,241,0.08)_0%,rgba(250,247,241,0)_36%,rgba(250,247,241,0.14)_100%)]"></div>
      </>
    )}
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-14 md:pt-24 md:pb-20 lg:pt-28 lg:pb-24 min-h-[72vh] flex items-end">
      <div class="max-w-2xl text-white animate-fade-in-up" style="opacity:0">
        <p class="font-condensed text-[0.78rem] uppercase tracking-[0.24em] text-linen-100/90 mb-4">
          Piglet&apos;s Gourmet Odyssey
        </p>
        <h1 class="font-serif text-5xl md:text-7xl lg:text-[5rem] font-semibold tracking-[0.01em] leading-[0.92] text-balance">
          Piglet&apos;s Gourmet Odyssey
        </h1>
        <p class="mt-4 text-sm md:text-base tracking-[0.12em] uppercase font-condensed text-linen-100/80">
          Warm table, sharp appetite
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.78rem] font-condensed uppercase tracking-[0.16em] text-linen-100/80">
          <span>{totalRecipes} Recipes</span>
          <span>{categories.length} Cuisines</span>
        </div>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="#favorites" class="btn-primary">查看收藏</a>
          <a href="#categories" class="btn-outline btn-outline-light">浏览菜系</a>
        </div>
      </div>
    </div>
  </section>

  <section id="favorites" class="py-16 md:py-20 bg-linen-100/70 border-y border-linen-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-header-row items-end">
        <div>
          <p class="eyebrow mb-3">Saved By You</p>
          <h2 class="section-heading text-3xl md:text-4xl">
            Favorite Recipes
          </h2>
        </div>
      </div>

      <div id="favorites-empty" class="favorites-empty mt-10">
        <svg class="w-12 h-12 mx-auto mb-4 text-copper-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
        </svg>
        <p class="font-serif text-2xl text-brown-800">还没有收藏的菜谱</p>
        <p class="mt-3 text-warm-gray-500 leading-7">先去点几道想做的菜，收藏区会在这里形成一条可以左右滑动的专属菜单。</p>
      </div>

      <div class="favorites-rail-wrap mt-10">
        <div id="favorites-grid" class="favorites-rail">
          {allRecipes.map((recipe) => {
            const rid = recipe.id.replace(/\.mdx?$/, '');
            return (
              <div class="rail-card" data-recipe-id={rid} hidden>
                <RecipeCard
                  title={recipe.data.title}
                  titleEn={recipe.data.titleEn}
                  category={recipe.data.category}
                  prepTime={recipe.data.prepTime}
                  cookTime={recipe.data.cookTime}
                  servings={recipe.data.servings}
                  coverImage={recipe.data.coverImage}
                  id={recipe.id}
                  compact={true}
                />
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <section id="categories" class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-header-row items-end">
        <div>
          <p class="eyebrow mb-3">Browse By Cuisine</p>
          <h2 class="section-heading text-3xl md:text-4xl">菜系分类</h2>
        </div>
      </div>

      <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3.5 md:gap-4">
        {categories.map((cat) => (
          <a
            href={cat.href}
            class="animate-on-scroll category-tile group"
          >
            <span class="mb-4 text-copper-700 group-hover:text-wine-700 transition-colors duration-300">
              <CategoryIcon name={cat.name} class="w-7.5 h-7.5 md:w-8 md:h-8" />
            </span>
            <span class="font-serif text-[1.02rem] md:text-[1.08rem] font-semibold text-brown-800 group-hover:text-wine-700 transition-colors duration-300">
              {cat.label}
            </span>
            <span class="mt-1 text-[0.68rem] font-condensed text-warm-gray-400 uppercase tracking-[0.18em]">
              {cat.labelEn}
            </span>
            <span class="text-[0.72rem] font-condensed text-warm-gray-400 mt-2 uppercase tracking-[0.16em]">
              {`${recipesByCategory[cat.name]?.length || 0} 道菜`}
            </span>
            <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 group-hover:w-10 h-0.5 bg-copper-500 rounded-full transition-all duration-500 ease-out"></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="archive" class="pb-20 md:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-header-row items-end">
        <div>
          <p class="eyebrow mb-3">Full Archive</p>
          <h2 class="section-heading text-3xl md:text-4xl">全部菜谱</h2>
        </div>
      </div>

      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {allRecipes.map((recipe) => (
          <div class="animate-on-scroll">
            <RecipeCard
              title={recipe.data.title}
              titleEn={recipe.data.titleEn}
              category={recipe.data.category}
              prepTime={recipe.data.prepTime}
              cookTime={recipe.data.cookTime}
              servings={recipe.data.servings}
              coverImage={recipe.data.coverImage}
              id={recipe.id}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</RecipeLayout>

<script>
  const STORAGE_KEY = 'recipe-likes';
  const grid = document.getElementById('favorites-grid');
  const empty = document.getElementById('favorites-empty');

  if (grid && empty) {
    grid.style.display = 'flex';
    grid.style.flexWrap = 'nowrap';
    grid.style.overflowX = 'auto';

    function getLikes(): string[] {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch { return []; }
    }

    const likes = getLikes();
    let shown = 0;

    grid.querySelectorAll<HTMLElement>('[data-recipe-id]').forEach((card) => {
      if (likes.includes(card.dataset.recipeId || '')) {
        card.removeAttribute('hidden');
        card.classList.add('is-visible');
        shown++;
      } else {
        card.setAttribute('hidden', '');
      }
    });

    if (shown > 0) {
      empty.hidden = true;
    } else {
      empty.hidden = false;
    }

    let isPointerDown = false;
    let startX = 0;
    let startScrollLeft = 0;
    let dragged = false;

    function handlePointerMove(event) {
      if (!isPointerDown) return;
      const delta = event.clientX - startX;
      if (Math.abs(delta) > 6) {
        dragged = true;
        grid.classList.add('is-dragging');
      }
      grid.scrollLeft = startScrollLeft - delta;
    }

    function stopDragging() {
      if (!isPointerDown) return;
      isPointerDown = false;
      grid.classList.remove('is-dragging');
      requestAnimationFrame(() => {
        dragged = false;
      });
    }

    grid.addEventListener('pointerdown', (event) => {
      isPointerDown = true;
      dragged = false;
      startX = event.clientX;
      startScrollLeft = grid.scrollLeft;
    });

    grid.addEventListener('pointermove', handlePointerMove);
    grid.addEventListener('pointerup', stopDragging);
    grid.addEventListener('pointerleave', stopDragging);
    grid.addEventListener('pointercancel', stopDragging);

    grid.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', (event) => {
        if (dragged) {
          event.preventDefault();
        }
      });
    });
  }
</script>
