---
import { getCollection } from 'astro:content';
import { parseRecipeBody } from '../utils/recipeBody';

const allRecipes = await getCollection('recipes');

const categories = [
  { name: '鲁', label: '鲁菜', labelEn: 'Shandong Cuisine', emoji: '🥬' },
  { name: '川', label: '川菜', labelEn: 'Sichuan Cuisine', emoji: '🌶️' },
  { name: '粤闽', label: '粤闽', labelEn: 'Cantonese & Fujian', emoji: '🥘' },
  { name: '淮扬', label: '淮扬', labelEn: 'Huaiyang Cuisine', emoji: '🍲' },
  { name: '徽湘', label: '徽湘', labelEn: 'Anhui & Hunan', emoji: '🐟' },
  { name: '云贵', label: '云贵', labelEn: 'Yunnan & Guizhou', emoji: '🦐' },
  { name: '意法', label: '意法', labelEn: 'Italian & French', emoji: '🍝' },
  { name: '南洋', label: '南洋', labelEn: 'Southeast Asian', emoji: '🍋' },
  { name: 'Silk-Road', label: '丝路', labelEn: 'Silk Road', emoji: '🛤️' },
  { name: 'Desserts', label: '甜点', labelEn: 'Desserts', emoji: '🍰' },
  { name: 'Drinks', label: '饮品', labelEn: 'Drinks', emoji: '🧋' },
];

const recipesByCategory = allRecipes.reduce((acc, recipe) => {
  const category = recipe.data.category;
  if (!acc[category]) acc[category] = [];
  acc[category].push({
    ...recipe.data,
    id: recipe.id,
    body: recipe.body,
    slug: recipe.id.replace(/\.mdx?$/, '').split('/').pop() || '',
  });
  return acc;
}, {} as Record<string, Array<typeof allRecipes[number]['data'] & { id: string; body: string; slug: string }>>);

const categoryLabels: Record<string, string> = {
  '鲁': '鲁菜',
  '川': '川菜',
  '粤闽': '粤闽',
  '淮扬': '淮扬',
  '徽湘': '徽湘',
  '云贵': '云贵',
  '意法': '意法',
  '南洋': '南洋',
  'Silk-Road': '丝路风味',
  'Desserts': '甜点',
  'Drinks': '饮品',
};

const coverRecipe = allRecipes[0];

function getRecipeSummary(body: string) {
  const lines = body
    .replace(/^---[\s\S]*?---\s*/, '')
    .split('\n')
    .map((line) => line.trim())
    .filter(Boolean)
    .filter((line) => !line.startsWith('##'))
    .filter((line) => !line.startsWith('###'))
    .filter((line) => !line.startsWith('|'))
    .filter((line) => !line.startsWith('-'))
    .filter((line) => !/^\d+\./.test(line));

  return lines[0] || 'A home-kitchen recipe arranged in a cleaner editorial rhythm.';
}
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Piglet’s Gourmet Odyssey | Print Book</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&family=Cormorant+Garamond:wght@400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --paper: #f7f0e6;
        --paper-soft: #fbf7f1;
        --ink: #3d302a;
        --muted: #78685c;
        --accent: #8e2f3f;
        --accent-soft: #f3e1d7;
        --line: #dcc8b5;
        --gold: #b88245;
      }

      @page {
        size: A4;
        margin: 0;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        font-family: "Noto Sans SC", system-ui, sans-serif;
        color: var(--ink);
        background: var(--paper);
      }

      body {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
        padding: 24px 0 48px;
      }

      .page {
        width: 210mm;
        min-height: 297mm;
        page-break-after: always;
        break-after: page;
        position: relative;
        overflow: hidden;
        background: var(--paper-soft);
        box-shadow: 0 24px 60px rgba(61, 48, 42, 0.14);
      }

      .cover-page {
        color: #fff8f0;
        display: flex;
        align-items: flex-end;
      }

      .cover-media,
      .section-media {
        position: absolute;
        inset: 0;
      }

      .cover-media img,
      .section-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .cover-overlay,
      .section-overlay {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(180deg, rgba(38, 21, 15, 0.12) 0%, rgba(38, 21, 15, 0.28) 38%, rgba(38, 21, 15, 0.72) 100%),
          linear-gradient(90deg, rgba(38, 21, 15, 0.56) 0%, rgba(38, 21, 15, 0.16) 55%, rgba(38, 21, 15, 0.3) 100%);
      }

      .cover-content {
        position: relative;
        z-index: 1;
        padding: 24mm 20mm 22mm;
        width: 100%;
      }

      .kicker {
        font-family: "Barlow Condensed", sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 10pt;
      }

      .cover-title {
        margin: 10mm 0 0;
        font-family: "Cormorant Garamond", "Noto Serif SC", serif;
        font-size: 39pt;
        line-height: 0.95;
        font-weight: 600;
        max-width: 120mm;
      }

      .cover-subtitle {
        margin: 4mm 0 0;
        font-family: "Barlow Condensed", sans-serif;
        font-size: 12pt;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: rgba(255, 248, 240, 0.82);
      }

      .cover-meta {
        margin-top: 10mm;
        display: flex;
        gap: 5mm;
        flex-wrap: wrap;
        font-family: "Barlow Condensed", sans-serif;
        font-size: 10pt;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .toc-page {
        padding: 18mm;
        background:
          radial-gradient(circle at top right, rgba(184, 130, 69, 0.12), transparent 30%),
          linear-gradient(180deg, #faf6f0 0%, #f7f0e6 100%);
      }

      .toc-header {
        display: grid;
        grid-template-columns: 1.3fr 0.7fr;
        gap: 10mm;
        align-items: end;
        margin-bottom: 14mm;
      }

      .toc-title {
        margin: 0;
        font-family: "Cormorant Garamond", "Noto Serif SC", serif;
        font-size: 28pt;
        line-height: 0.95;
      }

      .toc-note {
        margin: 0;
        color: var(--muted);
        font-size: 10.5pt;
        line-height: 1.7;
      }

      .toc-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 7mm 10mm;
      }

      .toc-block {
        background: rgba(255, 255, 255, 0.55);
        border: none;
        padding: 5mm;
        box-shadow: 0 14px 30px rgba(61, 48, 42, 0.06);
      }

      .toc-block h2 {
        margin: 0 0 3mm;
        font-family: "Noto Serif SC", serif;
        font-size: 15pt;
      }

      .toc-block p {
        margin: 0 0 3mm;
        color: var(--muted);
        font-family: "Barlow Condensed", sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 8.5pt;
      }

      .toc-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .toc-list li {
        padding: 1.5mm 0;
        border-top: 1px solid rgba(220, 200, 181, 0.7);
        font-size: 10pt;
      }

      .section-page {
        color: #fff8f0;
        display: flex;
        align-items: flex-end;
      }

      .section-content {
        position: relative;
        z-index: 1;
        padding: 20mm;
        width: 100%;
      }

      .section-title {
        margin: 2mm 0 0;
        font-family: "Cormorant Garamond", "Noto Serif SC", serif;
        font-size: 34pt;
        line-height: 0.95;
      }

      .section-subtitle {
        margin: 4mm 0 0;
        font-family: "Barlow Condensed", sans-serif;
        font-size: 11pt;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .section-count {
        margin-top: 6mm;
        display: inline-flex;
        padding: 2mm 4mm;
        border-radius: 999px;
        border: 1px solid rgba(255, 248, 240, 0.38);
        font-family: "Barlow Condensed", sans-serif;
        font-size: 9.5pt;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .recipe-page {
        padding: 12mm;
        background:
          radial-gradient(circle at top right, rgba(184, 130, 69, 0.1), transparent 24%),
          linear-gradient(180deg, #faf7f1 0%, #f7f1e8 100%);
      }

      .recipe-shell {
        height: calc(297mm - 24mm);
        display: grid;
        grid-template-rows: 98mm 1fr;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.4);
      }

      .recipe-hero {
        position: relative;
        min-height: 0;
      }

      .recipe-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .recipe-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(40, 23, 17, 0.1) 0%, rgba(40, 23, 17, 0.55) 100%);
      }

      .recipe-hero-copy {
        position: absolute;
        inset: auto 0 0 0;
        z-index: 1;
        padding: 9mm 8mm 8mm;
        color: #fff8f0;
      }

      .recipe-title {
        margin: 0;
        font-family: "Cormorant Garamond", "Noto Serif SC", serif;
        font-size: 25pt;
        line-height: 0.95;
      }

      .recipe-title-en {
        margin: 2.5mm 0 0;
        font-size: 10pt;
        color: rgba(255, 248, 240, 0.84);
      }

      .recipe-meta {
        margin-top: 4mm;
        display: flex;
        flex-wrap: wrap;
        gap: 4mm;
        font-family: "Barlow Condensed", sans-serif;
        font-size: 8.5pt;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .recipe-body {
        display: grid;
        grid-template-columns: 0.86fr 1.14fr;
        gap: 6mm;
        padding: 7mm 0 0;
        min-height: 0;
      }

      .recipe-column {
        display: grid;
        grid-template-rows: auto 1fr;
        gap: 6mm;
        min-height: 0;
        padding: 0 7mm 0 0;
      }

      .recipe-column + .recipe-column {
        padding: 0 0 0 7mm;
      }

      .recipe-notes-slot {
        min-height: 0;
      }

      .recipe-notes-slot:empty {
        display: none;
      }

      .recipe-panel {
        border-top: 1px solid rgba(220, 200, 181, 0.76);
        background: transparent;
        padding: 4.5mm 0 0;
        break-inside: avoid;
      }

      .panel-kicker {
        margin: 0 0 3mm;
        color: var(--accent);
        font-family: "Barlow Condensed", sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 8.5pt;
      }

      .ingredients-list,
      .tips-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .ingredients-list li {
        display: grid;
        grid-template-columns: 28mm 1fr;
        gap: 3mm;
        padding: 1.8mm 0;
        border-top: 1px solid rgba(220, 200, 181, 0.72);
        font-size: 9.2pt;
      }

      .ingredients-list li:first-child,
      .steps-list li:first-child,
      .tips-list li:first-child {
        border-top: none;
      }

      .amount {
        color: var(--muted);
      }

      .steps-list {
        list-style: none;
        margin: 0;
        padding: 0;
        counter-reset: step;
      }

      .steps-list li {
        counter-increment: step;
        display: grid;
        grid-template-columns: 8mm 1fr;
        gap: 3mm;
        padding: 1.8mm 0;
        border-top: 1px solid rgba(220, 200, 181, 0.7);
        font-size: 9.3pt;
        line-height: 1.45;
      }

      .steps-list li::before {
        content: counter(step, decimal-leading-zero);
        color: var(--accent);
        font-family: "Barlow Condensed", sans-serif;
        letter-spacing: 0.1em;
      }

      .ingredient-group + .ingredient-group {
        margin-top: 4mm;
      }

      .ingredient-group-heading {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 4mm;
        margin: 0 0 2.5mm;
        padding-bottom: 1.6mm;
        border-bottom: 1px solid rgba(220, 200, 181, 0.68);
        color: var(--gold);
        font-family: "Barlow Condensed", sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 8.3pt;
      }

      .ingredient-group-heading span:last-child {
        color: rgba(120, 104, 92, 0.72);
      }

      .tips-panel {
        background: transparent;
      }

      .recipe-notes-slot[data-slot="bottom"] .tips-panel {
        margin: 0 0 7mm;
      }

      .recipe-shell-compact .recipe-hero-copy {
        padding: 7mm 7mm 6mm;
      }

      .recipe-shell-compact {
        grid-template-rows: 88mm 1fr;
      }

      .recipe-shell-compact .recipe-title {
        font-size: 22pt;
      }

      .recipe-shell-compact .recipe-title-en {
        font-size: 9pt;
      }

      .recipe-shell-compact .recipe-meta {
        margin-top: 3mm;
        gap: 3mm;
        font-size: 8pt;
      }

      .recipe-shell-compact .recipe-body {
        gap: 5mm;
        padding: 6mm 0 0;
      }

      .recipe-shell-compact .recipe-column {
        gap: 5mm;
        padding: 0 6mm 0 0;
      }

      .recipe-shell-compact .recipe-column + .recipe-column {
        padding: 0 0 0 6mm;
      }

      .recipe-shell-compact .recipe-panel {
        padding: 4mm 0 0;
      }

      .recipe-shell-compact .panel-kicker {
        margin-bottom: 2.5mm;
        font-size: 8pt;
      }

      .recipe-shell-compact .ingredients-list li {
        padding: 1.5mm 0;
        font-size: 8.8pt;
      }

      .recipe-shell-compact .steps-list li {
        padding: 1.5mm 0;
        font-size: 8.9pt;
        line-height: 1.35;
      }

      .recipe-shell-compact .tips-list li {
        padding: 1.3mm 0;
        font-size: 8.4pt;
        line-height: 1.32;
      }

      .recipe-shell-tight {
        grid-template-rows: 80mm 1fr;
      }

      .recipe-shell-tight .recipe-title {
        font-size: 20pt;
      }

      .recipe-shell-tight .recipe-hero-copy {
        padding: 6mm 6mm 5mm;
      }

      .recipe-shell-tight .recipe-title-en {
        margin-top: 2mm;
        font-size: 8.5pt;
      }

      .recipe-shell-tight .recipe-meta {
        margin-top: 2.4mm;
        gap: 2.5mm;
        font-size: 7.6pt;
      }

      .recipe-shell-tight .recipe-body {
        gap: 4mm;
        padding: 5mm 0 0;
      }

      .recipe-shell-tight .recipe-column {
        padding: 0 5mm 0 0;
      }

      .recipe-shell-tight .recipe-column + .recipe-column {
        padding: 0 0 0 5mm;
      }

      .recipe-shell-tight .recipe-panel {
        padding: 3.6mm 0 0;
      }

      .recipe-shell-tight .ingredients-list li {
        font-size: 8.4pt;
      }

      .recipe-shell-tight .steps-list li {
        font-size: 8.5pt;
        line-height: 1.28;
      }

      .recipe-shell-tight .tips-list li {
        font-size: 8pt;
        line-height: 1.25;
      }

      .tips-list li {
        padding: 1.6mm 0;
        border-top: 1px solid rgba(220, 200, 181, 0.72);
        font-size: 8.9pt;
        line-height: 1.42;
      }

      .print-btn {
        position: fixed;
        right: 20px;
        bottom: 20px;
        border: none;
        border-radius: 999px;
        background: #8e2f3f;
        color: white;
        padding: 12px 18px;
        box-shadow: 0 12px 24px rgba(142, 47, 63, 0.28);
        cursor: pointer;
        font-size: 14px;
      }

      @media print {
        body {
          display: block;
          padding: 0;
        }

        .page {
          box-shadow: none;
        }

        .print-btn {
          display: none !important;
        }
      }
    </style>
  </head>
  <body>
    <section class="page cover-page">
      {coverRecipe && (
        <div class="cover-media">
          <img src={coverRecipe.data.coverImage} alt={coverRecipe.data.title} />
          <div class="cover-overlay"></div>
        </div>
      )}
      <div class="cover-content">
        <div class="kicker">Piglet&apos;s Gourmet Odyssey</div>
        <h1 class="cover-title">Piglet&apos;s Gourmet Odyssey</h1>
        <p class="cover-subtitle">A home kitchen book with warmer pages</p>
        <div class="cover-meta">
          <span>{allRecipes.length} Recipes</span>
          <span>{categories.filter((cat) => recipesByCategory[cat.name]?.length).length} Chapters</span>
          <span>{new Date().getFullYear()}</span>
        </div>
      </div>
    </section>

    <section class="page toc-page">
      <div class="toc-header">
        <div>
          <div class="kicker" style="color: var(--gold);">Contents</div>
          <h1 class="toc-title">目录不是索引，更像一份餐桌菜单。</h1>
        </div>
        <p class="toc-note">
          这一版 PDF 采用独立的册页排版逻辑，强调大图、少字、章节感和更稳定的分页控制，接近餐厅册页而不是普通打印文档。
        </p>
      </div>
      <div class="toc-grid">
        {categories.map((cat) => {
          const recipes = recipesByCategory[cat.name];
          if (!recipes?.length) return null;
          return (
            <section class="toc-block">
              <p>{cat.labelEn}</p>
              <h2>{cat.emoji} {cat.label}</h2>
              <ul class="toc-list">
                {recipes.map((recipe) => (
                  <li>{recipe.title}{recipe.titleEn ? ` / ${recipe.titleEn}` : ''}</li>
                ))}
              </ul>
            </section>
          );
        })}
      </div>
    </section>

    {categories.map((cat) => {
      const recipes = recipesByCategory[cat.name];
      if (!recipes?.length) return null;
      const sectionImage = recipes[0].coverImage;

      return (
        <>
          <section class="page section-page">
            <div class="section-media">
              <img src={sectionImage} alt={cat.label} />
              <div class="section-overlay"></div>
            </div>
            <div class="section-content">
              <div class="kicker">{cat.labelEn}</div>
              <h1 class="section-title">{cat.label}</h1>
              <p class="section-subtitle">Recipe Chapter</p>
              <div class="section-count">{recipes.length} recipes</div>
            </div>
          </section>

          {recipes.map((recipe) => {
            const { ingredientGroups, stepItems, tipItems } = parseRecipeBody(recipe.body || '');
            const recipeSummary = getRecipeSummary(recipe.body || '');

            return (
              <article class="page recipe-page">
                <div class="recipe-shell" data-recipe-shell>
                  <header class="recipe-hero">
                    <img src={recipe.coverImage} alt={recipe.title} />
                    <div class="recipe-hero-copy">
                      <div class="kicker">{categoryLabels[cat.name]}</div>
                      <h1 class="recipe-title">{recipe.title}</h1>
                      {recipe.titleEn && <p class="recipe-title-en">{recipe.titleEn}</p>}
                      <div class="recipe-meta">
                        {recipe.prepTime && <span>Prep {recipe.prepTime}</span>}
                        {recipe.cookTime && <span>Cook {recipe.cookTime}</span>}
                        {recipe.bakeTime && <span>{recipe.bakeTime}</span>}
                        {recipe.servings && <span>Serves {recipe.servings}</span>}
                      </div>
                    </div>
                  </header>

                  <div class="recipe-body">
                    <div class="recipe-column">
                      <section class="recipe-panel">
                        <p class="panel-kicker">Ingredients</p>
                        {ingredientGroups.map((group) => (
                          <div class="ingredient-group">
                            {group.title && (
                              <div class="ingredient-group-heading">
                                <span>{group.title}</span>
                                {group.titleEn && <span>{group.titleEn}</span>}
                              </div>
                            )}
                            <ul class="ingredients-list">
                              {group.rows.map((row) => (
                                <li>
                                  <span class="amount">{row.amount}</span>
                                  <span>{row.ingredient}</span>
                                </li>
                              ))}
                            </ul>
                          </div>
                        ))}
                      </section>
                      <div class="recipe-notes-slot" data-slot="left"></div>
                    </div>

                    <div class="recipe-column">
                      <section class="recipe-panel">
                        <p class="panel-kicker">Method</p>
                        <p style="margin: 0 0 3.2mm; color: var(--muted); font-size: 9pt; line-height: 1.5;">{recipeSummary}</p>
                        <ol class="steps-list">
                          {stepItems.map((step) => (
                            <li>{step}</li>
                          ))}
                        </ol>
                      </section>
                      <div class="recipe-notes-slot" data-slot="right"></div>
                    </div>
                  </div>

                  {tipItems.length > 0 && (
                    <>
                      <div class="recipe-notes-slot" data-slot="bottom"></div>
                      <section class="recipe-panel tips-panel recipe-notes-panel" data-notes-panel hidden>
                        <p class="panel-kicker">Notes</p>
                        <ul class="tips-list">
                          {tipItems.map((tip) => (
                            <li>{tip}</li>
                          ))}
                        </ul>
                      </section>
                    </>
                  )}
                </div>
              </article>
            );
          })}
        </>
      );
    })}

    <a class="print-btn" href="/Recipe/recipe-collection.pdf" download="Piglets-Gourmet-Odyssey.pdf">Download Generated PDF</a>
    <script>
      function placeRecipeNotes() {
        const shells = document.querySelectorAll('[data-recipe-shell]');

        shells.forEach((shell) => {
          const notesPanel = shell.querySelector('[data-notes-panel]');
          if (!notesPanel) return;

          const slots = Array.from(shell.querySelectorAll('.recipe-notes-slot'));
          let best = { overflow: Number.POSITIVE_INFINITY, slot: null, compact: '', index: -1 };

          const compactModes = ['', 'recipe-shell-compact', 'recipe-shell-tight'];

          compactModes.forEach((mode) => {
            shell.classList.remove('recipe-shell-compact', 'recipe-shell-tight');
            if (mode) shell.classList.add(mode);

            slots.forEach((slot, index) => {
              slot.appendChild(notesPanel);
              notesPanel.hidden = false;
              const overflow = shell.scrollHeight - shell.clientHeight;

              if (overflow <= 0) {
                best = { overflow, slot, compact: mode, index };
                return;
              }

              if (overflow < best.overflow) {
                best = { overflow, slot, compact: mode, index };
              }
            });

            if (best.overflow <= 0) return;
          });

          shell.classList.remove('recipe-shell-compact', 'recipe-shell-tight');
          if (best.compact) shell.classList.add(best.compact);

          const orderedSlots = slots.sort((a, b) => {
            const order = { left: 0, right: 1, bottom: 2 };
            return order[a.dataset.slot] - order[b.dataset.slot];
          });

          const finalSlot = best.slot || orderedSlots[orderedSlots.length - 1];
          finalSlot.appendChild(notesPanel);
          notesPanel.hidden = false;
        });
      }

      if (document.fonts?.ready) {
        document.fonts.ready.then(() => requestAnimationFrame(placeRecipeNotes));
      } else {
        window.addEventListener('load', placeRecipeNotes, { once: true });
      }
    </script>
  </body>
</html>
