---
const categories = [
  { name: '鲁', label: '鲁菜' },
  { name: '川', label: '川菜' },
  { name: '粤闽', label: '粤闽' },
  { name: '淮扬', label: '淮扬' },
  { name: '徽湘', label: '徽湘' },
  { name: '云贵', label: '云贵' },
  { name: '意法', label: '意法' },
  { name: '南洋', label: '南洋' },
  { name: 'Silk-Road', label: '丝路' },
  { name: 'Desserts', label: '甜点' },
  { name: 'Drinks', label: '饮品' },
];
---

<footer class="bg-linen-100 border-t border-linen-300 no-print">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <a href="/Recipe" class="inline-flex items-center gap-2.5 mb-3">
        <span class="text-2xl">🍳</span>
        <span class="font-display text-2xl font-bold text-wine-800 tracking-tight">Piglet&apos;s Gourmet Odyssey</span>
      </a>
      <p class="text-warm-gray-500 text-sm max-w-md mx-auto leading-relaxed">
        A personal collection of recipes from Chinese and international cuisines,
        crafted with care and shared with love.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-10">
      {categories.map((cat) => (
        <a
          href={`/Recipe/${cat.name}`}
          class="text-sm text-warm-gray-500 hover:text-wine-700 transition-colors duration-200"
        >
          {cat.label}
        </a>
      ))}
    </div>

    <div class="editorial-divider mb-8"></div>

    <p class="text-center text-xs text-warm-gray-400 tracking-wide">
      &copy; {new Date().getFullYear()} Piglet&apos;s Gourmet Odyssey &middot; Built with Astro
    </p>
  </div>
</footer>
