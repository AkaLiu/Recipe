---
import { getCollection } from 'astro:content';
import RecipeLayout from '../../layouts/RecipeLayout.astro';
import { parseRecipeBody } from '../../utils/recipeBody';
import { getRecipeImageSrc } from '../../utils/imageAssets';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => {
    const id = recipe.id;
    const slug = id.replace(/\.mdx?$/, '').split('/').pop() || '';
    return {
      params: {
        category: recipe.data.category,
        slug: slug
      },
      props: { recipe },
    };
  });
}

const { recipe } = Astro.props;
const recipeId = recipe.id.replace(/\.mdx?$/, '');
const { ingredientGroups, stepItems, tipItems, extras } = parseRecipeBody(recipe.body);
const coverImageSrc = getRecipeImageSrc(recipe.data.coverImage);

function getRecipeSummary(body: string) {
  const lines = body
    .replace(/^---[\s\S]*?---\s*/, '')
    .split('\n')
    .map((line) => line.trim())
    .filter(Boolean)
    .filter((line) => !line.startsWith('##'))
    .filter((line) => !line.startsWith('|'))
    .filter((line) => !line.startsWith('-'))
    .filter((line) => !/^\d+\./.test(line));

  return lines[0] || 'A composed dish page with cleaner spacing, concise copy, and a more menu-like editorial rhythm.';
}

const recipeSummary = getRecipeSummary(recipe.body);
---

<RecipeLayout
  title={`${recipe.data.title} | 菜谱`}
  description={recipe.data.titleEn || recipe.data.title}
>
  <article class="print:w-full print:p-0">
    <header class="hidden print:block mb-6 border-b-2 border-wine-700 pb-4">
      <div class="flex justify-between items-baseline">
        <h1 class="text-3xl font-bold text-wine-800 font-serif">{recipe.data.title}</h1>
        {recipe.data.titleEn && <span class="text-lg text-gray-500">{recipe.data.titleEn}</span>}
      </div>
      <p class="text-sm text-gray-600 mt-1">{recipe.data.category}</p>
    </header>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-14 no-print">
      <nav class="mb-8 flex items-center gap-2 text-sm text-warm-gray-400">
        <a href="/Recipe" class="hover:text-wine-700 transition-colors">Home</a>
        <span>/</span>
        <a href={`/Recipe/${recipe.data.category}`} class="hover:text-wine-700 transition-colors">{recipe.data.category}</a>
        <span>/</span>
        <span class="text-brown-800 font-medium">{recipe.data.title}</span>
      </nav>
    </div>

    <div class="hidden print:flex gap-6 mb-6 text-sm text-gray-700">
      {recipe.data.difficulty && <span><strong>难度:</strong> {recipe.data.difficulty}</span>}
    </div>

    <div class="recipe-content-grid pt-4 md:pt-6 print:p-0 print:max-w-none">
      <section class="recipe-editorial-hero">
        <img
          src={coverImageSrc}
          alt={recipe.data.title}
          class="recipe-editorial-hero-image"
        />
        <div class="recipe-editorial-hero-overlay"></div>
        <div class="recipe-editorial-hero-copy">
          <p class="recipe-editorial-kicker">{recipe.data.category}</p>
          <h1 class="recipe-editorial-title">{recipe.data.title}</h1>
          {recipe.data.titleEn && (
            <p class="recipe-editorial-subtitle">{recipe.data.titleEn}</p>
          )}
          <div class="recipe-editorial-meta">
            {recipe.data.prepTime && <span>{recipe.data.prepTime} Prep</span>}
            {recipe.data.cookTime && <span>{recipe.data.cookTime} Cook</span>}
            {recipe.data.servings && <span>{recipe.data.servings} Serves</span>}
            {recipe.data.bakeTime && <span>{recipe.data.bakeTime}</span>}
          </div>
        </div>
      </section>

      <section class="recipe-editorial-intro">
        <div class="recipe-editorial-summary">
          <p class="eyebrow mb-3">{recipe.data.category}</p>
          <p>{recipeSummary}</p>
        </div>
        <div class="recipe-editorial-aside">
          {recipe.data.robot && (
            <p><span>Equipment</span>{recipe.data.robot}</p>
          )}
          {recipe.data.coolTime && (
            <p><span>Rest</span>{recipe.data.coolTime}</p>
          )}
          <button id="like-btn" data-recipe-id={recipeId} class="recipe-like-button recipe-editorial-like">
            <svg class="w-5 h-5" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path class="heart-path" stroke-linecap="round" stroke-linejoin="round" fill="none" d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
            </svg>
            <span id="like-label" class="text-sm font-medium">Save This Dish</span>
          </button>
        </div>
      </section>

      <div class="recipe-editorial-grid">
        <aside class="recipe-editorial-panel recipe-editorial-panel-ingredients">
              <p class="recipe-book-panel-kicker">Ingredients</p>
              {ingredientGroups.map((group) => (
                <div class="recipe-ingredient-group">
                  {group.title && (
                    <div class="recipe-ingredient-group-heading">
                      <span>{group.title}</span>
                      {group.titleEn && <span>{group.titleEn}</span>}
                    </div>
                  )}
                  <table class="recipe-book-table">
                    <thead>
                      <tr>
                        <th>用量</th>
                        <th>食材</th>
                      </tr>
                    </thead>
                    <tbody>
                      {group.rows.map((row) => (
                        <tr>
                          <td>{row.amount}</td>
                          <td>{row.ingredient}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ))}
        </aside>

        <section class="recipe-editorial-panel recipe-editorial-panel-method">
              <p class="recipe-book-panel-kicker">Method</p>
              <ol class="recipe-book-steps">
                {stepItems.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>
        </section>
      </div>

      {tipItems.length > 0 && (
        <section class="recipe-editorial-notes">
          <p class="recipe-book-panel-kicker">Notes</p>
          <ul class="recipe-book-notes-list">
            {tipItems.map((tip) => (
              <li>{tip}</li>
            ))}
          </ul>
        </section>
      )}

      {extras.map((section) => (
        <section class="recipe-editorial-notes">
          <p class="recipe-book-panel-kicker">{section.title}</p>
          <ul class="recipe-book-notes-list">
            {section.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 no-print">
      <div class="border-t border-linen-200 pt-8">
        <div class="flex flex-wrap gap-4 items-center">
          <a href="/Recipe" class="btn-outline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            返回主菜单
          </a>
          <a href={`/Recipe/${recipe.data.category}`} class="btn-outline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            返回 {recipe.data.category}
          </a>
          <a
            href="/Recipe/recipe-collection.pdf"
            download="Piglets-Gourmet-Odyssey.pdf"
            class="btn-copper ml-auto"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download PDF Book
          </a>
        </div>
      </div>
    </div>
  </article>
</RecipeLayout>

<script>
  const likeBtn = document.getElementById('like-btn');
  const likeLabel = document.getElementById('like-label');

  if (likeBtn && likeLabel) {
    const recipeId = likeBtn.dataset.recipeId || '';
    const STORAGE_KEY = 'recipe-likes';

    function getLikes(): string[] {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch { return []; }
    }

    function isLiked(): boolean {
      return getLikes().includes(recipeId);
    }

    function updateUI() {
      const liked = isLiked();
      const heartPath = likeBtn.querySelector('.heart-path');
      if (liked) {
        heartPath?.setAttribute('fill', 'currentColor');
        likeBtn.classList.add('is-liked');
        likeLabel.textContent = '已收藏';
      } else {
        heartPath?.setAttribute('fill', 'none');
        likeBtn.classList.remove('is-liked');
        likeLabel.textContent = 'Save This Dish';
      }
    }

    likeBtn.addEventListener('click', () => {
      const likes = getLikes();
      const idx = likes.indexOf(recipeId);
      if (idx >= 0) {
        likes.splice(idx, 1);
      } else {
        likes.push(recipeId);
      }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(likes));
      updateUI();
    });

    updateUI();
  }
</script>
